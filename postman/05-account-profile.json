                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "apikey",
                "value": "{{supabase_anon_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"p_data\": {\n    \"email_marketing\": false,\n    \"sms_promotions\": true,\n    \"push_promotions\": true\n  }\n}"
            },
            "url": {
              "raw": "{{supabase_url}}/rest/v1/rpc/profile_update_notification_preferences",
              "host": ["{{supabase_url}}"],
              "path": ["rest", "v1", "rpc", "profile_update_notification_preferences"]
            }
          }
        }
      ]
    },
    {
      "name": "Privacy Settings",
      "item": [
        {
          "name": "1. Get Privacy Settings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns settings object', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.profile_id).to.exist;",
                  "  pm.expect(json.share_location).to.exist;",
                  "});"
                ],
