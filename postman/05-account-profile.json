            "url": {
              "raw": "{{supabase_url}}/rest/v1/rpc/profile_get_notification_preferences",
              "host": ["{{supabase_url}}"],
              "path": ["rest", "v1", "rpc", "profile_get_notification_preferences"]
            }
          }
        },
        {
          "name": "2. Update Notification Preferences",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
