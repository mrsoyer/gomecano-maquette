    {
      "name": "Company Management",
      "item": [
        {
          "name": "b2b_get_company",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "apikey",
                "value": "{{supabase_anon_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"p_company_id\": \"{{test_company_id}}\"\n}"
            },
            "url": {
              "raw": "{{supabase_url}}/rest/v1/rpc/b2b_get_company",
              "host": ["{{supabase_url}}"],
              "path": ["rest", "v1", "rpc", "b2b_get_company"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Company data returned', function() {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('name');",
                  "  pm.expect(data.name).to.equal('Transport Express Lyon');",
                  "});",
                  "",
                  "pm.test('Subscription included', function() {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('subscription');",
                  "  pm.expect(data.subscription.plan).to.equal('professional');",
                  "});",
                  "",
                  "pm.test('Sites array included', function() {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data.sites).to.be.an('array');",
                  "  pm.expect(data.sites.length).to.equal(3);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
