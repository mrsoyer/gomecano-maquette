{
  "info": {
    "name": "Session 09 - Modules (Chatbot, Analytics, Realtime)",
    "description": "Tests for modules Edge Function - chatbot, push notifications, analytics tracking",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "supabase_url",
      "value": "https://ymkdslderliwjuipeisz.supabase.co"
    },
    {
      "key": "anon_key",
      "value": "{{SUPABASE_ANON_KEY}}"
    },
    {
      "key": "auth_token",
      "value": "{{AUTH_TOKEN}}"
    }
  ],
  "item": [
    {
      "name": "Edge Function - Modules",
      "item": [
        {
          "name": "Chatbot - Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{anon_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"chatbot_respond\",\n  \"message\": \"Bonjour, quels services proposez-vous ?\"\n}"
            },
            "url": {
              "raw": "{{supabase_url}}/functions/v1/modules",
              "host": ["{{supabase_url}}"],
              "path": ["functions", "v1", "modules"]
            }
          }
        },
        {
          "name": "Chatbot - Continue Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{anon_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"chatbot_respond\",\n  \"message\": \"Combien coute une vidange ?\",\n  \"conversation_id\": \"{{conversation_id}}\"\n}"
            },
            "url": {
              "raw": "{{supabase_url}}/functions/v1/modules",
              "host": ["{{supabase_url}}"],
              "path": ["functions", "v1", "modules"]
            }
          }
        },
        {
          "name": "Track Analytics Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{anon_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"track_analytics\",\n  \"event_name\": \"page_view\",\n  \"properties\": {\n    \"page\": \"/services\",\n    \"referrer\": \"google\"\n  },\n  \"session_id\": \"sess_123456\",\n  \"page_url\": \"https://gomecano.fr/services\"\n}"
            },
            "url": {
              "raw": "{{supabase_url}}/functions/v1/modules",
              "host": ["{{supabase_url}}"],
              "path": ["functions", "v1", "modules"]
            }
          }
        },
        {
          "name": "Send Push Notification (Auth Required)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"send_push_notification\",\n  \"user_id\": \"a0000000-0000-0000-0000-000000000002\",\n  \"title\": \"Rappel RDV\",\n  \"body\": \"Votre rendez-vous est demain a 10h\",\n  \"data\": {\n    \"appointment_id\": \"875b7e27-9487-42c0-b2d4-cf7cdf9517a9\"\n  }\n}"
            },
            "url": {
              "raw": "{{supabase_url}}/functions/v1/modules",
              "host": ["{{supabase_url}}"],
              "path": ["functions", "v1", "modules"]
            }
          }
        }
      ]
