{
  "info": {
    "_postman_id": "b2c-home-gomecano",
    "name": "Gomecano B2C Home API",
    "description": "Collection pour tester les fonctions B2C Home (services, testimonials, stats)\n\n## Configuration requise\n\n1. Définir les variables d'environnement :\n   - `SUPABASE_URL`: URL de votre projet Supabase\n   - `SUPABASE_ANON_KEY`: Clé anon publique\n\n2. Ces fonctions sont publiques (pas d'AUTH_TOKEN requis).\n\n## Session: 02-b2c-home\n## Date: 2026-01-06",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "SUPABASE_URL",
      "value": "https://your-project.supabase.co",
      "type": "string"
    },
    {
      "key": "SUPABASE_ANON_KEY",
      "value": "your-anon-key",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Services",
      "description": "Fonctions pour récupérer les services",
      "item": [
        {
          "name": "home_get_services",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{SUPABASE_ANON_KEY}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/rest/v1/rpc/home_get_services",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["rest", "v1", "rpc", "home_get_services"]
            },
            "description": "Retourne tous les services actifs avec transformation camelCase.\n\nOutput:\n```json\n{\n  \"success\": true,\n  \"data\": [...services],\n  \"count\": 30\n}\n```"
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "POST",
                "url": "{{SUPABASE_URL}}/rest/v1/rpc/home_get_services"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"id\": \"uuid\",\n      \"slug\": \"vidange-huile-moteur\",\n      \"name\": \"Vidange huile moteur\",\n      \"description\": \"Remplacement complet de l'huile moteur\",\n      \"priceFrom\": 69,\n      \"duration\": 45,\n      \"category\": \"entretien\",\n      \"imageUrl\": \"/images/services/vidange.jpg\",\n      \"badges\": [\"populaire\", \"rapide\"],\n      \"isInstantQuote\": true,\n      \"included\": [\"Huile moteur\", \"Filtre à huile\"],\n      \"recommended\": true\n    }\n  ],\n  \"count\": 30\n}"
            }
          ]
        },
        {
          "name": "home_get_service (existing slug)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{SUPABASE_ANON_KEY}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"p_slug\": \"vidange-huile-moteur\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{SUPABASE_URL}}/rest/v1/rpc/home_get_service",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["rest", "v1", "rpc", "home_get_service"]
            },
            "description": "Retourne un service par son slug.\n\nInput: `p_slug` (TEXT)\n\nOutput:\n```json\n{\n  \"success\": true,\n  \"data\": { ...service }\n}\n```"
          },
          "response": [
            {
              "name": "Success - Service Found",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"uuid\",\n    \"slug\": \"vidange-huile-moteur\",\n    \"name\": \"Vidange huile moteur\",\n    \"priceFrom\": 69\n  }\n}"
            }
          ]
        },
